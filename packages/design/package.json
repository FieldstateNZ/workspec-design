{
  "name": "@workspec/design",
  "version": "0.1.0-alpha.0",
  "description": "WorkSpec design system tokens, themes, and self-hosted fonts — extracted from WorkSpec Enterprise for reuse across Decision Studio, product sites, and future mini-apps.",
  "keywords": [
    "design-tokens",
    "design-system",
    "tailwindcss",
    "css-variables",
    "theming"
  ],
  "homepage": "https://github.com/FieldstateNZ/workspec-design#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FieldstateNZ/workspec-design.git",
    "directory": "packages/design"
  },
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "tokens.css",
    "tailwind.css",
    "tokens.json",
    "themes",
    "fonts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "@workspec/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./tokens.css",
    "./tailwind.css": "./tailwind.css",
    "./tailwind": "./tailwind.css",
    "./tokens.json": "./tokens.json",
    "./themes/console-dark.css": "./themes/console-dark.css",
    "./themes/console-light.css": "./themes/console-light.css",
    "./fonts.css": "./fonts.css",
    "./fonts/*": "./fonts/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gen:tokens": "tsx scripts/generate.ts"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
